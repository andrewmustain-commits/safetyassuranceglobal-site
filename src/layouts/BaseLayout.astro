---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Safety Assurance Global</title>
    <style>
      :root { font-family: Arial, sans-serif; }
      body { margin: 0; line-height: 1.6; color: #102a43; }
      header, main, footer { padding: 1rem; max-width: 960px; margin: 0 auto; }
      nav { display: flex; flex-wrap: wrap; gap: 0.75rem; }
      a { color: #0057b8; text-decoration: none; }
      a:hover { text-decoration: underline; }
      h1, h2 { color: #003366; }
      .card { border: 1px solid #d9e2ec; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1rem; }
    </style>
  </head>
  <body>
    <header>
      <h1>Safety Assurance Global</h1>
      <nav>
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/services">Services</a>
        <a href="/industries">Industries</a>
        <a href="/training">Training</a>
        <a href="/academy">Academy</a>
        <a href="/blog">Blog</a>
        <a href="/contact">Contact</a>
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/terms">Terms</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <small>© {new Date().getFullYear()} Safety Assurance Global</small>
    </footer>
  </body>
</html>
