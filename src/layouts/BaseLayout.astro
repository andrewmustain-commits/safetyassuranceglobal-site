---
import '../styles/design-system.css';
import Container from '../components/ui/Container.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Safety Assurance Global provides practical safety assurance consulting, industry programs, and workforce development.',
  image = '/social-card-default.png'
} = Astro.props;

const navigation = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/industries', label: 'Industries' },
  { href: '/academy', label: 'Academy' },
  { href: '/command', label: 'SAG Command' },
  { href: '/training', label: 'Training' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' }
];

const currentPath = Astro.url.pathname;
const normalizedPath = currentPath !== '/' && currentPath.endsWith('/') ? currentPath.slice(0, -1) : currentPath;
const isHome = normalizedPath === '/';

const breadcrumbLabelMap: Record<string, string> = {
  about: 'About',
  services: 'Services',
  industries: 'Industries',
  academy: 'Academy',
  command: 'SAG Command',
  training: 'Training',
  blog: 'Blog',
  contact: 'Contact',
  'privacy-policy': 'Privacy Policy',
  'terms-of-use': 'Terms of Use',
  terms: 'Terms'
};

const pathParts = normalizedPath.split('/').filter(Boolean);

const toTitleCase = (value: string) =>
  value
    .replace(/[-_]/g, ' ')
    .replace(/\b\w/g, (char) => char.toUpperCase());

const breadcrumbs = pathParts.map((segment, index) => {
  const href = `/${pathParts.slice(0, index + 1).join('/')}/`;
  const isLast = index === pathParts.length - 1;
  const mapped = breadcrumbLabelMap[segment];
  const label = isLast && !mapped ? title : mapped ?? toTitleCase(segment);
  return { href, label, isLast };
});

const hideUnifiedCta = ['/privacy-policy', '/terms-of-use', '/terms'].includes(normalizedPath);
const canonicalUrl = Astro.url.href;
const ogImage = new URL(image, Astro.url.origin).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Safety Assurance Global" />
    <meta property="og:title" content={`${title} | Safety Assurance Global`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Safety Assurance Global`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="generator" content={Astro.generator} />
    <title>{title} | Safety Assurance Global</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header class="site-header">
      <Container class="header-inner">
        <a href="/" class="brand">Safety Assurance Global</a>
        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="primary-nav-list">
          Menu
        </button>
        <nav aria-label="Primary navigation" class="primary-nav" data-open="false">
          <ul id="primary-nav-list">
            {navigation.map((item) => (
              <li>
                <a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>{item.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </Container>
    </header>
    <main id="main-content" class="site-main">
      {!isHome && (
        <Container>
          <nav class="breadcrumbs" aria-label="Breadcrumb">
            <ol>
              <li><a href="/">Home</a></li>
              {breadcrumbs.map((crumb) => (
                <li aria-current={crumb.isLast ? 'page' : undefined}>
                  {crumb.isLast ? <span>{crumb.label}</span> : <a href={crumb.href}>{crumb.label}</a>}
                </li>
              ))}
            </ol>
          </nav>
        </Container>
      )}
      <slot />
      {!hideUnifiedCta && (
        <section class="site-cross-cta" aria-labelledby="site-cross-cta-title">
          <Container class="site-cross-cta-inner">
            <div>
              <p class="site-cross-eyebrow">Explore Safety Assurance Global</p>
              <h2 id="site-cross-cta-title">Connect services, capability development, and command-center operations.</h2>
            </div>
            <div class="site-cross-actions">
              <a class="ui-button ui-button-secondary" href="/services">Services</a>
              <a class="ui-button ui-button-secondary" href="/academy">Academy</a>
              <a class="ui-button ui-button-secondary" href="/command">SAG Command</a>
              <a class="ui-button ui-button-primary" href="/contact">Contact</a>
            </div>
          </Container>
        </section>
      )}
    </main>
    <footer class="site-footer">
      <Container class="footer-shell">
        <section class="footer-company" aria-labelledby="footer-company-title">
          <h2 id="footer-company-title">Safety Assurance Global</h2>
          <p>
            Enterprise advisory, learning, and operational command support for safety, governance, and assurance.
          </p>
        </section>
        <nav class="footer-nav" aria-label="Footer navigation">
          <section>
            <h3>Quick Links</h3>
            <ul>
              <li><a href="/">Home</a></li>
              <li><a href="/about">About</a></li>
              <li><a href="/industries">Industries</a></li>
              <li><a href="/blog">Blog</a></li>
            </ul>
          </section>
          <section>
            <h3>Solutions</h3>
            <ul>
              <li><a href="/services">Services</a></li>
              <li><a href="/academy">Academy</a></li>
              <li><a href="/command">SAG Command</a></li>
              <li><a href="/contact">Contact</a></li>
            </ul>
          </section>
          <section>
            <h3>Policies</h3>
            <ul>
              <li><a href="/privacy-policy">Privacy Policy</a></li>
              <li><a href="/terms-of-use">Terms of Use</a></li>
            </ul>
          </section>
        </nav>
        <p class="footer-meta">© {new Date().getFullYear()} Safety Assurance Global. All rights reserved.</p>
      </Container>
    </footer>
    <script>
      const nav = document.querySelector('.primary-nav');
      const toggle = document.querySelector('.nav-toggle');

      if (nav && toggle) {
        const setState = (open) => {
          nav.dataset.open = String(open);
          toggle.setAttribute('aria-expanded', String(open));
        };

        toggle.addEventListener('click', () => {
          setState(nav.dataset.open !== 'true');
        });

        nav.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => setState(false));
        });

        window.addEventListener('resize', () => {
          if (window.innerWidth > 860) {
            setState(false);
          }
        });
      }
    </script>
  </body>
</html>
