---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import Badge from '../../components/ui/Badge.astro';

const approvedPosts = (await getCollection('blog', ({ data }) => data.status === 'approved'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const [featuredPost, ...otherPosts] = approvedPosts;
---

<BaseLayout title="Blog" description="Safety assurance insights and updates from Safety Assurance Global.">
  <div class="blog-shell">
    <Container>
      <Section class="blog-hero" ariaLabelledby="blog-hero-title">
        <Badge text="Thought Leadership" />
        <h1 id="blog-hero-title">SAG Blog</h1>
        <p>Practical guidance, insights, and updates from our safety assurance specialists.</p>
      </Section>

      {approvedPosts.length === 0 ? (
        <Section>
          <Card class="empty-card" as="div">
            <p>No approved posts are available yet.</p>
          </Card>
        </Section>
      ) : (
        <>
          <Section ariaLabelledby="featured-post-title">
            <div class="section-head">
              <Badge text="Featured Approved Post" />
              <h2 id="featured-post-title">Latest approved publication.</h2>
            </div>
            <Card class="featured-card" as="article">
              <p class="meta-row">
                <time datetime={featuredPost.data.date.toISOString()}>
                  {featuredPost.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {' · '}
                <span>{featuredPost.data.author}</span>
                {' · '}
                <span>{featuredPost.data.category}</span>
              </p>
              <h3>
                <a href={`/blog/${featuredPost.data.slug}/`}>{featuredPost.data.title}</a>
              </h3>
              <p>{featuredPost.data.summary}</p>
              <div class="tags-row" aria-label="Post tags">
                {featuredPost.data.tags.map((tag) => (
                  <span class="tag-chip">{tag}</span>
                ))}
              </div>
            </Card>
          </Section>

          {otherPosts.length > 0 && (
            <Section ariaLabelledby="all-posts-title">
              <div class="section-head">
                <Badge text="Approved Articles" />
                <h2 id="all-posts-title">More from Safety Assurance Global.</h2>
              </div>
              <div class="posts-grid">
                {otherPosts.map((post) => (
                  <Card class="post-card" as="article">
                    <p class="meta-row">
                      <time datetime={post.data.date.toISOString()}>
                        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                      </time>
                      {' · '}
                      <span>{post.data.category}</span>
                    </p>
                    <h3>
                      <a href={`/blog/${post.data.slug}/`}>{post.data.title}</a>
                    </h3>
                    <p>{post.data.summary}</p>
                    <p class="author-row">By {post.data.author}</p>
                    <div class="tags-row" aria-label="Post tags">
                      {post.data.tags.map((tag) => (
                        <span class="tag-chip">{tag}</span>
                      ))}
                    </div>
                  </Card>
                ))}
              </div>
            </Section>
          )}
        </>
      )}
    </Container>
  </div>
</BaseLayout>

<style>
  .blog-shell {
    padding-bottom: var(--space-4);
  }

  .blog-hero {
    border: var(--border-strong);
    border-radius: var(--radius-lg);
    background: linear-gradient(145deg, rgba(8, 20, 39, 0.96), rgba(5, 14, 28, 0.98));
    box-shadow: var(--shadow-panel);
    padding: clamp(1.25rem, 2.6vw, 1.9rem);
  }

  .blog-hero h1 {
    margin-top: 0.75rem;
    margin-bottom: 0.7rem;
    font-size: clamp(2rem, 4vw, 2.7rem);
  }

  .blog-hero p {
    max-width: 70ch;
    margin-bottom: 0;
  }

  .section-head {
    display: grid;
    gap: 0.6rem;
    margin-bottom: var(--space-2);
  }

  .section-head h2 {
    margin: 0;
    max-width: 36ch;
    font-size: clamp(1.3rem, 2.3vw, 1.8rem);
  }

  .featured-card,
  .post-card,
  .empty-card {
    border-color: rgba(111, 167, 236, 0.3);
    background: rgba(8, 20, 39, 0.9);
  }

  .meta-row,
  .author-row {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-text-soft);
  }

  .featured-card h3,
  .post-card h3 {
    margin: 0.6rem 0 0;
    font-size: 1.25rem;
    line-height: 1.3;
  }

  .post-card h3 {
    font-size: 1.12rem;
  }

  .featured-card p,
  .post-card p {
    margin-top: 0.65rem;
  }

  .featured-card a,
  .post-card a {
    color: var(--color-text);
    text-decoration: none;
  }

  .featured-card a:hover,
  .featured-card a:focus-visible,
  .post-card a:hover,
  .post-card a:focus-visible {
    color: var(--color-link-hover);
    text-decoration: underline;
  }

  .posts-grid {
    display: grid;
    gap: var(--space-2);
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .tags-row {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.8rem;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    border: 1px solid rgba(111, 224, 190, 0.52);
    background: rgba(111, 224, 190, 0.14);
    color: var(--color-accent-green-strong);
    font-size: 0.73rem;
    line-height: 1;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.5rem;
  }

  @media (max-width: 760px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
