---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHero from '../components/home/HomeHero.astro';
import CapabilityCards from '../components/home/CapabilityCards.astro';
import ServicesOverview from '../components/home/ServicesOverview.astro';
import AcademyHighlight from '../components/home/AcademyHighlight.astro';
import CommandPreview from '../components/home/CommandPreview.astro';
import BlogPreview from '../components/home/BlogPreview.astro';
import ContactCta from '../components/home/ContactCta.astro';

const approvedPosts = (await getCollection('blog', ({ data }) => data.status === 'approved'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)
  .map((post) => ({
    slug: post.data.slug,
    title: post.data.title,
    summary: post.data.summary,
    author: post.data.author,
    date: post.data.date,
    category: post.data.category
  }));
---

<BaseLayout title="Home" description="Safety Assurance Global helps leaders build safer operations with practical assurance, training, and governance.">
  <div class="home-shell">
    <div class="container home-stack">
      <HomeHero />
      <CapabilityCards />
      <ServicesOverview />
      <AcademyHighlight />
      <CommandPreview />
      <BlogPreview posts={approvedPosts} />
      <ContactCta />
    </div>
  </div>
</BaseLayout>
