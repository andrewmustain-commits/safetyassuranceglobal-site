---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contact Safety Assurance Global for consulting, training, and academy inquiries.">
  <section class="hero">
    <div class="container">
      <h1>Contact</h1>
      <p>Connect with SAG to discuss consulting engagements, training options, or partnership opportunities.</p>
    </div>
  </section>

  <section class="section">
    <div class="container grid">
      <div class="card">
        <h3>General inquiries</h3>
        <p><a href="mailto:info@safetyassuranceglobal.com">info@safetyassuranceglobal.com</a></p>
      </div>
      <div class="card">
        <h3>Engagements</h3>
        <p><a href="mailto:advisory@safetyassuranceglobal.com">advisory@safetyassuranceglobal.com</a></p>
      </div>
      <div class="card">
        <h3>Training & Academy</h3>
        <p><a href="mailto:academy@safetyassuranceglobal.com">academy@safetyassuranceglobal.com</a></p>
      </div>
    </div>
  </section>
</BaseLayout>
