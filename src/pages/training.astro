---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Training" description="Practical safety assurance training programs for leaders, practitioners, and operational teams.">
  <section class="hero">
    <div class="container">
      <h1>Training</h1>
      <p>Role-based programs that build confidence in assurance methods, governance responsibilities, and operational decision-making.</p>
    </div>
  </section>

  <section class="section">
    <div class="container grid">
      <div class="card"><h3>Executive Briefings</h3><p>Focused sessions for leaders on accountability, assurance governance, and decision quality.</p></div>
      <div class="card"><h3>Practitioner Bootcamps</h3><p>Hands-on training in assurance planning, evidence management, and review techniques.</p></div>
      <div class="card"><h3>Team Workshops</h3><p>Scenario-based facilitation to align cross-functional teams around practical controls.</p></div>
    </div>
  </section>
</BaseLayout>
