---
interface BlogPost {
  slug: string;
  title: string;
  summary: string;
  author: string;
  date: Date;
  category: string;
}

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="section-shell" aria-labelledby="blog-preview-title">
    <div class="section-head">
      <p class="section-label">Approved Insights</p>
      <h2 id="blog-preview-title">From the SAG blog</h2>
      <a class="section-link" href="/blog">Visit blog</a>
    </div>

    <div class="blog-grid">
      {posts.map((post) => (
        <article class="blog-card">
          <p class="meta">
            <time datetime={post.date.toISOString()}>
              {post.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {' · '}
            <span>{post.category}</span>
          </p>
          <h3>
            <a href={`/blog/${post.slug}/`}>{post.title}</a>
          </h3>
          <p>{post.summary}</p>
          <p class="author">By {post.author}</p>
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-bottom: 0.95rem;
  }

  .section-label {
    margin: 0;
    color: var(--home-accent-green);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.76rem;
    width: 100%;
  }

  .section-head h2 {
    margin: 0;
    font-size: clamp(1.35rem, 2.4vw, 1.8rem);
  }

  .section-link {
    width: fit-content;
    color: var(--home-text);
    border: 1px solid rgba(84, 145, 227, 0.4);
    border-radius: 0.65rem;
    padding: 0.45rem 0.7rem;
    text-decoration: none;
    background: rgba(84, 145, 227, 0.08);
    font-size: 0.92rem;
  }

  .section-link:hover,
  .section-link:focus-visible {
    border-color: rgba(111, 220, 190, 0.6);
    background: rgba(111, 220, 190, 0.12);
    outline: none;
  }

  .blog-grid {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .blog-card {
    background: rgba(8, 20, 39, 0.9);
    border: 1px solid rgba(74, 137, 221, 0.28);
    border-radius: 0.9rem;
    padding: 1rem;
  }

  .meta {
    margin: 0;
    color: var(--home-text-muted);
    font-size: 0.82rem;
  }

  .blog-card h3 {
    margin: 0.55rem 0 0;
    font-size: 1.05rem;
    line-height: 1.3;
  }

  .blog-card h3 a {
    color: var(--home-text);
    text-decoration: none;
  }

  .blog-card h3 a:hover,
  .blog-card h3 a:focus-visible {
    color: var(--home-accent-green);
    outline: none;
  }

  .blog-card p {
    margin: 0.6rem 0 0;
    color: var(--home-text-muted);
    font-size: 0.92rem;
  }

  .author {
    color: var(--home-text-soft);
    font-size: 0.84rem;
  }

  @media (max-width: 980px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>