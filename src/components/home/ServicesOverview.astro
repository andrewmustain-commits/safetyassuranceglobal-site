---
const services = [
  {
    title: 'Safety Governance Design',
    description: 'Define ownership models and decision rights that keep assurance activity consistent.'
  },
  {
    title: 'Assurance Frameworks',
    description: 'Build fit-for-purpose assurance structures with practical controls and review rhythms.'
  },
  {
    title: 'Independent Reviews',
    description: 'Assess maturity and identify high-impact opportunities for performance improvement.'
  }
];
---

<section class="section-shell" aria-labelledby="services-title">
  <div class="section-head">
    <p class="section-label">Services</p>
    <h2 id="services-title">Service lines for strategy-to-execution assurance.</h2>
    <a class="section-link" href="/services">View full services</a>
  </div>

  <div class="services-grid">
    {services.map((service) => (
      <article class="service-card">
        <h3>{service.title}</h3>
        <p>{service.description}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .section-head {
    display: grid;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .section-label {
    margin: 0;
    color: var(--home-accent-green);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.76rem;
  }

  .section-head h2 {
    margin: 0;
    font-size: clamp(1.35rem, 2.4vw, 1.85rem);
  }

  .section-link {
    width: fit-content;
    color: var(--home-text);
    border: 1px solid rgba(84, 145, 227, 0.42);
    border-radius: 0.65rem;
    padding: 0.45rem 0.7rem;
    text-decoration: none;
    background: rgba(84, 145, 227, 0.08);
    font-size: 0.92rem;
  }

  .section-link:hover,
  .section-link:focus-visible {
    border-color: rgba(111, 220, 190, 0.6);
    background: rgba(111, 220, 190, 0.12);
    outline: none;
  }

  .services-grid {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .service-card {
    padding: 1.05rem;
    border-radius: 0.9rem;
    background: rgba(7, 17, 34, 0.86);
    border: 1px solid rgba(74, 137, 221, 0.26);
    box-shadow: 0 9px 24px rgba(0, 0, 0, 0.26);
  }

  .service-card h3 {
    margin: 0;
    font-size: 1.05rem;
  }

  .service-card p {
    margin: 0.65rem 0 0;
    color: var(--home-text-muted);
    font-size: 0.95rem;
  }

  @media (max-width: 980px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>